{
  "name": "autoify-platform",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "web": "pnpm --filter web dev",
    "api": "pnpm --filter api dev",
    "prisma:generate": "pnpm --filter api exec prisma generate",
    "prisma:push": "pnpm --filter api exec prisma db push"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20.0.0",
    "autoprefixer": "^10.4.27",
    "class-validator": "0.14",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "turbo": "^2.8.17",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "class-transformer": "0.5"
  }
}
