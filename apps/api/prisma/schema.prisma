// Autoify V2 — Prisma Schema
// Multi-tenant automation platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////////////////////
//// TENANT (White-label organization)
////////////////////////////////////////////////

model Tenant {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique
  domain  String? @unique
  logoUrl String?

  primaryColor   String @default("#6366f1")
  secondaryColor String @default("#8b5cf6")

  plan     Plan    @default(STARTER)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  workflows    Workflow[]
  integrations Integration[]
  executions   Execution[]
  apiKeys      ApiKey[]

  @@map("tenants")
}

enum Plan {
  STARTER
  PRO
  ENTERPRISE
}

////////////////////////////////////////////////
//// USER
////////////////////////////////////////////////

model User {
  id        String  @id @default(cuid())
  email     String
  name      String?
  avatarUrl String?

  role UserRole @default(MEMBER)

  googleId     String?
  passwordHash String?

  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  workflows  Workflow[]
  executions Execution[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

////////////////////////////////////////////////
//// WORKFLOW
////////////////////////////////////////////////

model Workflow {
  id String @id @default(cuid())

  name        String
  description String?

  graph      Json // React Flow nodes/edges
  isActive   Boolean @default(false)
  isTemplate Boolean @default(false)

  triggerType TriggerType @default(MANUAL)

  webhookUrl String?
  schedule   String? // cron expression

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  executions Execution[]

  @@unique([tenantId, webhookUrl])
  @@index([tenantId])
  @@index([userId])
  @@map("workflows")
}

enum TriggerType {
  MANUAL
  WEBHOOK
  SCHEDULE
  EMAIL
  FORM
}

////////////////////////////////////////////////
//// WORKFLOW EXECUTION
////////////////////////////////////////////////

model Execution {
  id String @id @default(cuid())

  status ExecutionStatus @default(PENDING)

  triggerData Json?
  result      Json?
  logs        Json?

  startedAt   DateTime?
  completedAt DateTime?

  duration Int?
  error    String?

  retryCount Int @default(0)

  createdAt DateTime @default(now())

  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([workflowId])
  @@index([tenantId])
  @@index([status])
  @@map("executions")
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

////////////////////////////////////////////////
//// INTEGRATIONS
////////////////////////////////////////////////

model Integration {
  id String @id @default(cuid())

  provider IntegrationProvider
  name     String

  credentials Json
  metadata    Json?

  isConnected Boolean @default(false)

  connectedAt DateTime?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@map("integrations")
}

enum IntegrationProvider {
  GMAIL
  SLACK
  STRIPE
  TWILIO
  OPENAI
  WEBHOOK
}

////////////////////////////////////////////////
//// API KEYS
////////////////////////////////////////////////

model ApiKey {
  id String @id @default(cuid())

  name      String
  keyHash   String @unique
  keyPrefix String

  lastUsedAt DateTime?
  expiresAt  DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("api_keys")
}
