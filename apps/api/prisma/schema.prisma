// Autoify V2 — Prisma Schema
// Multi-tenant automation platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// TENANT (White-label Organization)
// ============================================
model Tenant {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  domain          String?  @unique
  logoUrl         String?
  primaryColor    String   @default("#6366f1")
  secondaryColor  String   @default("#8b5cf6")
  plan            Plan     @default(STARTER)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users        User[]
  workflows    Workflow[]
  integrations Integration[]
  executions   Execution[]
  apiKeys      ApiKey[]

  @@map("tenants")
}

enum Plan {
  STARTER
  PRO
  ENTERPRISE
}

// ============================================
// USER
// ============================================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  role          UserRole  @default(MEMBER)
  googleId      String?   @unique
  passwordHash  String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  workflows  Workflow[]
  executions Execution[]

  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

// ============================================
// WORKFLOW
// ============================================
model Workflow {
  id          String         @id @default(cuid())
  name        String
  description String?
  graph       Json           // React Flow graph: { nodes, edges }
  isActive    Boolean        @default(false)
  isTemplate  Boolean        @default(false)
  triggerType TriggerType    @default(MANUAL)
  webhookUrl  String?        @unique
  schedule    String?        // cron expression
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User   @relation(fields: [userId], references: [id])

  executions Execution[]

  @@map("workflows")
}

enum TriggerType {
  MANUAL
  WEBHOOK
  SCHEDULE
  EMAIL
  FORM
}

// ============================================
// EXECUTION (Single workflow run)
// ============================================
model Execution {
  id          String          @id @default(cuid())
  status      ExecutionStatus @default(PENDING)
  triggerData Json?           // input payload
  result      Json?           // final output
  logs        Json?           // step-by-step log array
  startedAt   DateTime?
  completedAt DateTime?
  duration    Int?            // ms
  error       String?
  createdAt   DateTime        @default(now())

  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  @@map("executions")
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

// ============================================
// INTEGRATION (Connected Apps)
// ============================================
model Integration {
  id           String   @id @default(cuid())
  provider     String   // gmail | slack | stripe | twilio | openai
  name         String
  credentials  Json     // encrypted { accessToken, refreshToken, apiKey, ... }
  isConnected  Boolean  @default(false)
  connectedAt  DateTime?
  expiresAt    DateTime?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@map("integrations")
}

// ============================================
// API KEY
// ============================================
model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  keyPrefix   String    // first 8 chars for display: "ak_1a2b3c..."
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}
