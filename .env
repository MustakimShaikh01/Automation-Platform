# ============================================
# AUTOIFY V2 — Environment Variables
# ============================================

# -- App --
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-nextauth-key-change-in-prod

# -- Database --
DATABASE_URL=postgresql://autoify:autoify_pass@localhost:5433/autoify_db

# -- Redis --
REDIS_URL=redis://localhost:6379

# -- Google OAuth --
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -- JWT --
JWT_SECRET=your-jwt-secret-min-32-chars-change-in-prod
JWT_EXPIRES_IN=7d

# -- OpenAI --
OPENAI_API_KEY=sk-your-openai-api-key

# -- Twilio --
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# -- Email (SendGrid) --
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@autoify.com

# -- AWS S3 --
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_NAME=autoify-logs

# -- API --
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
WEBHOOK_SECRET=your-webhook-hmac-secret

# -- Rate Limiting --
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
