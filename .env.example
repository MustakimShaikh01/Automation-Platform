# ============================================
# AUTOIFY V2 — LOCAL DEV ENV (WORKING)
# ============================================

# -- App --
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-123456789012345678901234567890

# -- Database (make sure Postgres is running) --
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autoify_db

# -- Redis (optional but recommended) --
REDIS_URL=redis://localhost:6379

# -- Google OAuth (optional for now) --
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -- JWT --
JWT_SECRET=dev-jwt-secret-123456789012345678901234
JWT_EXPIRES_IN=7d

# -- OpenAI (optional for now) --
OPENAI_API_KEY=

# -- Twilio (optional for now) --
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# -- Email (optional) --
SENDGRID_API_KEY=
EMAIL_FROM=noreply@autoify.local

# -- AWS (optional) --
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=autoify-logs

# -- API --
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
WEBHOOK_SECRET=dev-webhook-secret

# -- Rate Limiting --
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100


